# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY=cole-aqui-a-chave-fernet

# Token pra criar o primeiro admin em /admin/bootstrap. Troque e guarde.
BOOTSTRAP_TOKEN=troque-isto

# Banco. Local usa SQLite; em producao aponte pro Postgres do Railway:
DATABASE_URL=sqlite:///./uniassinatura.db
# DATABASE_URL=postgresql+psycopg://user:senha@host:5432/uniassinatura

# TSA ICP-Brasil (carimbo de tempo). Opcional. Vazio = usa horario do servidor.
TSA_URL=
